# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost/vacation_rental

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-change-in-production

# ── App ───────────────────────────────────────────────────────
APP_NAME=Drivra
FRONTEND_URL=http://localhost:5173

# ── Flutterwave (Payment Gateway) ────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key

# ── Email (SMTP) ──────────────────────────────────────────────
# For Gmail: enable "App Passwords" in your Google account settings
# then use your Gmail address as SMTP_USER and the App Password as SMTP_PASSWORD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# ── SMS (Twilio) ──────────────────────────────────────────────
# Sign up at https://www.twilio.com to get these credentials
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
